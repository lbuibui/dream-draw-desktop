{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "绘梦桌面版默认权限配置",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "dialog:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "http:default",
    "http:allow-fetch",
    "store:default",
    "store:allow-get",
    "store:allow-set",
    "store:allow-save",
    "store:allow-delete",
    "store:allow-keys"
  ]
}
